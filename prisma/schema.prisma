generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(customer)
  cart      Cart?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal
  stock       Int      @default(0)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  customer
  admin
}

model Cart {
  // Chave primária
  id        String     @id @default(uuid())

  // Chave estrangeira — referencia o usuário dono do carrinho
  // @unique garante que cada usuário tem no máximo um carrinho
  userId    String     @unique

  // Relacionamento — o Prisma usa isso para fazer joins automáticos
  user      User       @relation(fields: [userId], references: [id])

  // Lista de itens do carrinho — um carrinho tem vários CartItems
  items     CartItem[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  // Chave primária
  id        String   @id @default(uuid())

  // Chave estrangeira para o carrinho
  cartId    String

  // Chave estrangeira para o produto
  productId String

  // Quantidade desse produto no carrinho
  quantity  Int      @default(1)

  // Relacionamentos
  cart      Cart     @relation(fields: [cartId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Garante que o mesmo produto não apareça duas vezes no mesmo carrinho
  // Se o usuário adicionar o mesmo produto, incrementamos a quantidade
  @@unique([cartId, productId])
}

  model Order {
  // Chave primária
  id        String      @id @default(uuid())

  // Usuário que fez o pedido
  userId    String

  // Status do pedido — começa como "pending"
  status    OrderStatus @default(pending)

  // Valor total do pedido — calculado na hora de criar
  total     Decimal

  // Lista de itens do pedido
  items     OrderItem[]

  // Relacionamento com o usuário
  user      User        @relation(fields: [userId], references: [id])

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  // Chave primária
  id        String   @id @default(uuid())

  // Pedido ao qual pertence
  orderId   String

  // Produto comprado
  productId String

  // Quantidade comprada
  quantity  Int

  // Preço no momento da compra — importante!
  // O preço do produto pode mudar depois, mas o pedido deve manter o preço original
  price     Decimal

  // Relacionamentos
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

// Status possíveis de um pedido
enum OrderStatus {
  pending    // Aguardando pagamento
  paid       // Pago
  shipped    // Enviado
  delivered  // Entregue
  cancelled  // Cancelado
}
